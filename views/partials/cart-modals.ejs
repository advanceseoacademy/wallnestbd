<div class="modal-overlay" id="loginModal">
  <div class="modal">
    <div class="modal-header"><h3>👤 লগইন</h3><button class="modal-close" type="button" onclick="closeModal('loginModal')">✕</button></div>
    <div class="modal-body">
      <button type="button" class="btn-google" onclick="signInWithGoogle(event)">
        <span class="btn-google-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303C33.654 32.657 29.223 36 24 36c-5.522 0-10-4.478-10-10s4.478-10 10-10c2.426 0 4.652.86 6.391 2.278l5.657-5.657C33.64 10.053 29.082 8 24 8 12.955 8 4 16.955 4 28s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 16.108 18.961 13 24 13c2.426 0 4.652.86 6.391 2.278l5.657-5.657C33.64 10.053 29.082 8 24 8c-7.682 0-14.344 4.337-17.694 10.691z"/><path fill="#4CAF50" d="M24 48c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 38.091 26.715 39 24 39c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 43.556 16.227 48 24 48z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 28c0-1.341-.138-2.65-.389-3.917z"/></svg>
        </span>
        Google দিয়ে চালিয়ে যান
      </button>
      <div class="auth-divider"><span>অথবা</span></div>
      <form onsubmit="login(event)">
        <div class="form-group"><label class="form-label">ইমেইল</label><input type="email" class="form-input" id="loginEmail" required></div>
        <div class="form-group"><label class="form-label">পাসওয়ার্ড</label><input type="password" class="form-input" id="loginPassword" required></div>
        <button class="btn-block" type="submit">লগইন</button>
      </form>
      <p style="text-align:center;margin-top:14px;font-size:13.5px;color:var(--text-muted)">অ্যাকাউন্ট নেই? <a href="#" style="color:var(--primary);font-weight:600;" onclick="closeModal('loginModal'); openModal('registerModal'); return false;">রেজিস্ট্রেশন</a></p>
    </div>
  </div>
</div>

<div class="modal-overlay" id="registerModal">
  <div class="modal">
    <div class="modal-header"><h3>📝 রেজিস্ট্রেশন</h3><button class="modal-close" type="button" onclick="closeModal('registerModal')">✕</button></div>
    <div class="modal-body">
      <button type="button" class="btn-google" onclick="signInWithGoogle(event)">
        <span class="btn-google-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303C33.654 32.657 29.223 36 24 36c-5.522 0-10-4.478-10-10s4.478-10 10-10c2.426 0 4.652.86 6.391 2.278l5.657-5.657C33.64 10.053 29.082 8 24 8 12.955 8 4 16.955 4 28s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 16.108 18.961 13 24 13c2.426 0 4.652.86 6.391 2.278l5.657-5.657C33.64 10.053 29.082 8 24 8c-7.682 0-14.344 4.337-17.694 10.691z"/><path fill="#4CAF50" d="M24 48c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 38.091 26.715 39 24 39c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 43.556 16.227 48 24 48z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 28c0-1.341-.138-2.65-.389-3.917z"/></svg>
        </span>
        Google দিয়ে সাইন আপ
      </button>
      <div class="auth-divider"><span>অথবা</span></div>
      <form onsubmit="register(event)">
        <div class="form-row">
          <div class="form-group"><label class="form-label">প্রথম নাম</label><input type="text" class="form-input" id="regFirst" required></div>
          <div class="form-group"><label class="form-label">শেষ নাম</label><input type="text" class="form-input" id="regLast"></div>
        </div>
        <div class="form-group"><label class="form-label">ইমেইল</label><input type="email" class="form-input" id="regEmail" required></div>
        <div class="form-group"><label class="form-label">পাসওয়ার্ড</label><input type="password" class="form-input" id="regPassword" required minlength="8"></div>
        <button class="btn-block" type="submit">অ্যাকাউন্ট তৈরি</button>
      </form>
    </div>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>
