<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('partials/favicon') %>
<%- include('partials/seo-meta', { seo: typeof seo !== 'undefined' ? seo : null, siteUrl: typeof siteUrl !== 'undefined' ? siteUrl : '' }) %>
<% if (typeof seo === 'undefined' || !seo) { %><title>WallNest BD - Online Store</title><% } %>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css?v=37">
</head>
<body>

<%- include('partials/site-header', { categories, cartCount, user, activeNav: 'home' }) %>

<section class="hero">
  <div class="hero-inner site-wrap">
    <div>
      <div class="banner-tag">🖼️ Beautiful Walls, Better Living</div>
      <h1>ওয়াল আর্ট ও <span>ক্যানভাস</span> — WallNest BD</h1>
      <p>ইসলামিক আর্ট, ফ্যামিলি ফটো ক্যানভাস, কিডস রুম ও অফিস মোটিভেশনাল — বাংলাদেশে ডেলিভারি।</p>
      <div class="hero-btns">
        <a href="#products" class="btn-primary">🛍️ এখনই কিনুন / Shop Now</a>
        <a href="/track-order" class="btn-outline">📦 অর্ডার ট্র্যাক করুন</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><div class="stat-num">4</div><div class="stat-label">ক্যাটাগরি / Categories</div></div>
        <div class="stat"><div class="stat-num">20+</div><div class="stat-label">ওয়াল আর্ট / Designs</div></div>
        <div class="stat"><div class="stat-num">4.8★</div><div class="stat-label">রেটিং / Rating</div></div>
        <div class="stat"><div class="stat-num">3-5d</div><div class="stat-label">প্রিন্ট ও ডেলিভারি</div></div>
      </div>
    </div>
    <div class="hero-visual">
      <% const heroCards = (categories || []).filter(function(c) { return c.slug && c.slug !== 'all'; }).sort(function(a, b) { return (a.sort_order || 0) - (b.sort_order || 0); }).slice(0, 4); %>
      <% heroCards.forEach(function(c, i) { %>
      <a href="/category/<%= c.slug %>" class="hero-card">
        <img src="<%= c.heroImageUrl || c.hero_image_url %>" alt="<%= c.name_bn || c.name_en %>" class="hero-card-img" <%= i === 0 ? 'fetchpriority="high" decoding="async"' : 'loading="lazy"' %>>
        <span class="hero-card-label"><%= c.name_bn || c.name_en %></span>
      </a>
      <% }); %>
    </div>
  </div>
</section>

<div class="categories">
  <div class="site-wrap">
  <div class="cat-grid" id="catGrid">
    <% categories.forEach(function(c, i) { %>
      <a href="<%= c.slug === 'all' ? '/' : '/category/' + encodeURIComponent(c.slug) %>" class="cat-chip <%= i === 0 ? 'active' : '' %>" data-cat="<%= c.slug %>">
        <div class="cat-icon"><%= c.icon %></div>
        <span><%= c.name_bn || c.name_en %></span>
      </a>
    <% }); %>
  </div>
  </div>
</div>

<div class="features-bar">
  <div class="features-grid site-wrap">
    <div class="feature-item"><div class="feature-icon">🚚</div><div class="feature-text"><strong>ফ্রি শিপিং</strong><span>৳1500+ অর্ডারে</span></div></div>
    <div class="feature-item"><div class="feature-icon">🔄</div><div class="feature-text"><strong>৩০ দিনের রিটার্ন</strong><span>30-Day Easy Returns</span></div></div>
    <div class="feature-item"><div class="feature-icon">🔒</div><div class="feature-text"><strong>নিরাপদ পেমেন্ট</strong><span>100% Secure Checkout</span></div></div>
    <div class="feature-item"><div class="feature-icon">✅</div><div class="feature-text"><strong>bKash · Rocket · Nagad</strong><span>ম্যানুয়াল পেমেন্ট</span></div></div>
  </div>
</div>

<div class="site-wrap site-main">
  <div class="section">
    <div class="banner-row">
      <div class="banner-main">
        <div class="banner-tag">⚡ সীমিত সময়ের অফার</div>
        <h2>ওয়াল আর্ট সেল<br>সর্বোচ্চ ৪০% ছাড়!</h2>
        <p>ইসলামিক, ফ্যামিলি ক্যানভাস ও কিডস রুম — আজই অর্ডার করুন।</p>
        <button class="btn-primary" type="button" onclick="document.getElementById('products').scrollIntoView({behavior:'smooth'})">Shop Now →</button>
      </div>
      <div class="banner-small b1">
        <h3>নতুন আরাইভাল 🆕</h3>
        <p>সর্বশেষ প্রোডাক্ট দেখুন</p>
        <a href="/new-arrivals" class="btn-sm" style="display:inline-block;text-align:center;text-decoration:none;">View All →</a>
        <div class="big-icon">✨</div>
      </div>
      <div class="banner-small b2">
        <h3>Clearance Sale 🏷️</h3>
        <p>পুরনো স্টক, নতুন দামে</p>
        <button class="btn-sm" type="button">Shop →</button>
        <div class="big-icon">💜</div>
      </div>
    </div>
  </div>

  <div class="flash-sale-block">
    <div class="flash-sale-header">
      <div class="flash-title">⚡ ফ্ল্যাশ সেল / Flash Sale</div>
      <div class="countdown">
        <div class="countdown-block"><span class="countdown-num" id="hours">00</span><span class="countdown-label">ঘণ্টা</span></div>
        <span class="countdown-sep">:</span>
        <div class="countdown-block"><span class="countdown-num" id="minutes">00</span><span class="countdown-label">মিনিট</span></div>
        <span class="countdown-sep">:</span>
        <div class="countdown-block"><span class="countdown-num" id="seconds">00</span><span class="countdown-label">সেকেন্ড</span></div>
      </div>
    </div>
    <div class="flash-carousel" id="flashCarousel">
      <div class="flash-carousel-viewport" id="flashCarouselViewport" aria-label="Flash sale products">
        <div class="flash-products" id="flashProducts">
          <% flashProducts.forEach(function(p) { %>
            <%- include('partials/product-card', { p: p }) %>
          <% }); %>
          <% if (flashProducts.length >= 2) { flashProducts.forEach(function(p) { %>
            <%- include('partials/product-card', { p: p }) %>
          <% }); } %>
        </div>
      </div>
    </div>
  </div>

  <div class="section new-arrivals-block" id="new-arrivals">
    <div class="section-header">
      <div class="section-title">🆕 নতুন আরাইভাল / <span>New Arrival</span></div>
      <% if (newArrivalProducts && newArrivalProducts.length) { %>
      <a href="/new-arrivals" class="see-all">View All →</a>
      <% } %>
    </div>
    <% if (newArrivalProducts && newArrivalProducts.length) { %>
    <div class="new-arrivals-carousel" id="newArrivalsCarousel">
      <div class="new-arrivals-carousel-viewport" id="newArrivalsCarouselViewport" aria-label="New arrival products">
        <div class="new-arrivals-track" id="newArrivalsTrack">
          <% newArrivalProducts.forEach(function(p) { %>
            <%- include('partials/product-card', { p: p }) %>
          <% }); %>
          <% if (newArrivalProducts.length >= 2) { newArrivalProducts.forEach(function(p) { %>
            <%- include('partials/product-card', { p: p }) %>
          <% }); } %>
        </div>
      </div>
    </div>
    <% } else { %>
    <div class="new-arrivals-empty">
      <p>এখনো নতুন পণ্য নেই। অ্যাডমিন প্যানেল থেকে <strong>+ নতুন পণ্য</strong> যোগ করুন।</p>
    </div>
    <% } %>
  </div>

  <div id="category-sections">
    <% (categorySections || []).forEach(function(sec) { %>
      <%- include('partials/category-section', { sec: sec }) %>
    <% }); %>
  </div>

  <div class="section" id="customer-reviews">
    <div class="section-header">
      <div class="section-title">💬 গ্রাহকের মতামত / <span>Customer Reviews</span></div>
      <% if (reviews && reviews.length) { %>
      <a href="/reviews" class="see-all">View All →</a>
      <% } %>
    </div>
    <% if (reviews && reviews.length) { %>
    <div class="reviews-carousel" id="reviewsCarousel">
      <div class="reviews-carousel-viewport" id="reviewsCarouselViewport" aria-label="Customer reviews">
        <div class="reviews-track" id="reviewsTrack">
          <% reviews.forEach(function(r, i) { %>
            <%- include('partials/review-card', { r: r, i: i }) %>
          <% }); %>
          <% if (reviews.length > 4) { reviews.forEach(function(r, i) { %>
            <%- include('partials/review-card', { r: r, i: i }) %>
          <% }); } %>
        </div>
      </div>
    </div>
    <% } else { %>
    <div class="new-arrivals-empty">
      <p>এখনো কোনো রিভিউ নেই।</p>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/site-footer') %>

<%- include('partials/cart-modals') %>

<script>
  window.__PRODUCTS__ = <%- JSON.stringify(products) %>;
  window.__FLASH__ = <%- JSON.stringify(flashProducts) %>;
</script>
<script src="/js/app.js"></script>
</body>
</html>
