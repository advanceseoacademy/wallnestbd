<%- include('partials/head', { title: 'সেটিংস' }) %>
<%- include('partials/sidebar', { page: 'settings', admin }) %>
<div class="main">
  <div class="topbar">
    <div>
      <div class="page-title">সেটিংস</div>
      <div class="page-subtitle">হিরো ছবি ও ডেলিভারি চার্জ সেটিংস</div>
    </div>
    <div class="topbar-right">
      <a href="/admin/categories" class="card-btn" style="text-decoration:none;">📁 ক্যাটাগরি সম্পাদন</a>
      <a href="/" target="_blank" class="card-btn active" style="text-decoration:none;margin-left:8px;">🌐 স্টোর দেখুন</a>
    </div>
  </div>
  <div class="content">
    <div class="card" style="margin-bottom:20px;">
      <div class="card-header">
        <div class="card-title"><div class="dot"></div> ডেলিভারি চার্জ</div>
      </div>
      <div class="card-body">
        <p class="admin-catalog-note" style="margin-bottom:16px;">
          চেকআউটে গ্রাহক <strong>Inside Dhaka</strong> বা <strong>Outside Dhaka</strong> বেছে নেবেন। ৳+ ফ্রি ডেলিভারি সীমার উপরে শিপিং ফ্রি।
        </p>
        <form id="shippingSettingsForm" class="shipping-settings-form">
          <div class="form-grid-shipping">
            <div class="form-group">
              <label class="form-label" for="freeShippingMin">ফ্রি ডেলিভারি (৳+ অর্ডার)</label>
              <input type="number" class="form-input" id="freeShippingMin" min="0" step="1" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="insideDhakaFee">Inside Dhaka চার্জ (৳)</label>
              <input type="number" class="form-input" id="insideDhakaFee" min="0" step="1" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="outsideDhakaFee">Outside Dhaka চার্জ (৳)</label>
              <input type="number" class="form-input" id="outsideDhakaFee" min="0" step="1" required>
            </div>
          </div>
          <button type="submit" class="card-btn active" id="btnSaveShipping">সেভ করুন</button>
          <p class="hero-slot-meta" id="shippingSaveStatus" style="margin-top:10px;min-height:18px;"></p>
        </form>
      </div>
    </div>
    <div class="card">
      <div class="card-header">
        <div class="card-title"><div class="dot"></div> হোমপেজ হিরো ছবি</div>
      </div>
      <div class="card-body">
        <p class="admin-catalog-note" style="margin-bottom:20px;">
          কোন ৪টি কার্ড দেখাবে তা <strong>ক্যাটাগরি → সাজানোর ক্রম</strong> (১–৪) দিয়ে ঠিক হয়। এখানে শুধু ছবি আপলোড করুন।
        </p>
        <div id="heroSlots" class="hero-settings-grid"></div>
      </div>
    </div>
  </div>
</div>
<style>
.hero-settings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; }
.hero-slot-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 16px; }
.hero-slot-card img { width: 100%; height: 140px; object-fit: cover; border-radius: 10px; background: var(--border); }
.hero-slot-card h4 { margin: 12px 0 4px; font-size: 15px; }
.hero-slot-card .hero-slot-meta { font-size: 12px; color: var(--muted); margin-bottom: 12px; }
.hero-slot-card input[type=file] { width: 100%; font-size: 12px; margin-bottom: 10px; }
.hero-slot-empty { color: var(--muted); font-size: 13px; padding: 24px; text-align: center; }
.form-grid-shipping { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 16px; }
.shipping-settings-form .form-label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
.shipping-settings-form .form-input { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; }
</style>
<script src="/js/admin-common.js"></script>
<script src="/js/admin-settings.js"></script>
</body></html>
