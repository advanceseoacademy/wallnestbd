<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('partials/favicon') %>
<%- include('partials/seo-meta', { seo: typeof seo !== 'undefined' ? seo : null, siteUrl: typeof siteUrl !== 'undefined' ? siteUrl : '' }) %>
<% if (typeof seo === 'undefined' || !seo) { %>
<title><%= product.name %> — WallNest BD</title>
<meta name="description" content="<%= product.name %> — <%= product.desc ? product.desc.slice(0, 120) : 'WallNest BD' %>">
<% } %>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css?v=57">
</head>
<body>

<%- include('partials/site-header', { categories, cartCount, user, activeNav: product.catSlug, storeSettings }) %>

<div class="product-page">
  <div class="product-page-inner site-wrap">
    <nav class="breadcrumb">
      <a href="/">হোম</a> /
      <a href="/category/<%= product.catSlug %>"><%= product.cat %></a> /
      <span><%= product.name %></span>
    </nav>

    <% const galleryImages = (product.images && product.images.length) ? product.images : (product.imageUrl ? [product.imageUrl] : []); %>
    <div class="product-detail">
      <div class="product-gallery-col">
        <div class="product-gallery">
          <% if (product.badge) { %>
            <span class="product-detail-badge <%= product.badge %>">
              <%= product.badge === 'sale' ? '🔥 SALE' : product.badge === 'new' ? '🆕 NEW' : '🌶️ HOT' %>
            </span>
          <% } %>
          <div class="product-gallery-main" id="mainImage">
            <% if (galleryImages.length) { %>
              <img src="<%= galleryImages[0] %>" alt="<%= product.name %>" id="galleryImg">
            <% } else { %>
              <span class="product-gallery-emoji"><%= product.icon %></span>
            <% } %>
          </div>
          <% if (galleryImages.length > 1) { %>
            <div class="product-gallery-thumbs" id="galleryThumbs">
              <% galleryImages.forEach(function(url, i) { %>
                <button type="button" class="gallery-thumb <%= i === 0 ? 'active' : '' %>" data-src="<%= url %>" aria-label="ছবি <%= i + 1 %>">
                  <img src="<%= url %>" alt="<%= product.name %> — ছবি <%= i + 1 %>">
                </button>
              <% }); %>
            </div>
          <% } %>
        </div>
        <div class="product-mini-perks">
          <div class="mini-perk"><span>🚚</span><div><strong>ফ্রি ডেলিভারি</strong><small>৳<%= ((storeSettings && storeSettings.freeShippingMin) || 1500).toLocaleString('en-US') %>+ অর্ডারে</small></div></div>
          <div class="mini-perk"><span>🔒</span><div><strong>নিরাপদ পেমেন্ট</strong><small>bKash · Rocket · Nagad</small></div></div>
          <div class="mini-perk"><span>🔄</span><div><strong>সহজ রিটার্ন</strong><small>৩০ দিনের মধ্যে</small></div></div>
        </div>
      </div>

      <div class="product-info">
        <div class="product-cat"><%= product.cat %></div>
        <h1 class="product-title"><%= product.name %></h1>
        <% if (product.nameBn) { %><p class="product-title-bn"><%= product.nameBn %></p><% } %>

        <div class="product-rating product-rating-lg">
          <span class="stars"><%= '★'.repeat(Math.floor(product.rating)) %><%= '☆'.repeat(5 - Math.floor(product.rating)) %></span>
          <span class="rating-count"><%= product.rating %> · <%= product.reviews.toLocaleString() %> রিভিউ</span>
          <a href="#reviews" class="rating-link">রিভিউ দেখুন ↓</a>
        </div>

        <div class="product-price product-price-lg" id="productPriceBlock">
          <% if (product.fromPrice) { %><span class="price-from-label">শুরু</span><% } %>
          <span class="price-current" id="productPriceCurrent">৳<%= product.price.toLocaleString('bn-BD') %></span>
          <span class="price-original" id="productPriceOriginal" <%= product.original > product.price ? '' : 'style="display:none"' %>>৳<%= product.original.toLocaleString('bn-BD') %></span>
          <span class="price-save" id="productPriceSave" <%= product.original > product.price ? '' : 'style="display:none"' %>>সেভ ৳<%= (product.original - product.price).toLocaleString('bn-BD') %> (<%= Math.round((1 - product.price / product.original) * 100) %>% ছাড়)</span>
          <span class="price-unit-hint" id="productPriceUnitHint" hidden></span>
        </div>

        <% if (product.sizes && product.sizes.length) { %>
        <div class="product-size-row">
          <span class="size-label">সাইজ নির্বাচন করুন:</span>
          <div class="product-size-options" id="productSizeOptions">
            <% product.sizes.forEach(function(s, i) { %>
              <button type="button"
                class="size-option <%= i === 0 ? 'active' : '' %>"
                data-label="<%= s.label %>"
                data-price="<%= s.price %>"
                data-original="<%= s.original %>"
                data-stock="<%= s.stock %>"
                <%= s.stock <= 0 ? 'disabled' : '' %>>
                <%= s.label %>
              </button>
            <% }); %>
          </div>
        </div>
        <% } %>

        <div class="product-meta-row">
          <span>SKU: <strong><%= product.sku %></strong></span>
          <span>ব্র্যান্ড: <strong>WallNest BD</strong></span>
        </div>

        <p class="product-desc-short"><%= product.descPlain || product.desc || '' %></p>

        <div class="product-stock <%= product.stock > 0 ? 'in-stock' : 'out-stock' %>" id="productStockLine">
          <%= product.stock > 0 ? `✅ স্টকে আছে — ${(product.sizes && product.sizes[0]) ? product.sizes[0].stock : product.stock} পিস বাকি` : '❌ স্টক শেষ — শীঘ্রই আসছে' %>
        </div>

        <div class="qty-row">
          <span class="qty-label">পরিমাণ:</span>
          <div class="qty-control">
            <button type="button" class="qty-btn-lg" onclick="changeProductQty(-1)">−</button>
            <input type="number" id="productQty" value="1" min="1" max="<%= Math.min(product.stock, 99) %>" readonly>
            <button type="button" class="qty-btn-lg" onclick="changeProductQty(1)">+</button>
          </div>
        </div>

        <div class="product-actions">
          <button type="button" class="btn-add-cart btn-lg" onclick="addToCartWithQty(<%= JSON.stringify(product.id) %>)" <%= product.stock <= 0 ? 'disabled' : '' %>>🛒 কার্টে যোগ করুন</button>
          <button type="button" class="btn-buy-now btn-lg" onclick="buyNowWithQty(<%= JSON.stringify(product.id) %>)" <%= product.stock <= 0 ? 'disabled' : '' %>>⚡ এখনই কিনুন</button>
        </div>

        <div class="share-row">
          <span class="share-label">শেয়ার করুন</span>
          <div class="share-buttons">
            <button type="button" class="share-btn share-whatsapp" onclick="shareWhatsApp()" title="WhatsApp">WhatsApp</button>
            <button type="button" class="share-btn share-facebook" onclick="shareFacebook()" title="Facebook">Facebook</button>
            <button type="button" class="share-btn share-messenger" onclick="shareMessenger()" title="Messenger">Messenger</button>
            <button type="button" class="share-btn share-telegram" onclick="shareTelegram()" title="Telegram">Telegram</button>
            <button type="button" class="share-btn share-twitter" onclick="shareTwitter()" title="X (Twitter)">X</button>
            <button type="button" class="share-btn share-copy" onclick="copyProductLink()" title="লিংক কপি">লিংক কপি</button>
          </div>
        </div>
      </div>
    </div>

    <!-- TABS -->
    <div class="product-tabs-card">
      <div class="product-tabs">
        <button type="button" class="product-tab active" data-tab="desc">বিবরণ</button>
        <button type="button" class="product-tab" data-tab="specs">স্পেসিফিকেশন</button>
        <button type="button" class="product-tab" data-tab="reviews">রিভিউ (<%= productReviews.length %>)</button>
        <button type="button" class="product-tab" data-tab="delivery">ডেলিভারি</button>
      </div>
      <div class="product-tab-panel active" id="tab-desc">
        <h3>পণ্যের বিবরণ</h3>
        <% if (product.descHtml) { %>
        <div class="product-desc-rich"><%- product.descHtml %></div>
        <% } else { %>
        <p><%= product.descPlain || product.desc || 'এই পণ্যের বিস্তারিত বিবরণ শীঘ্রই যোগ করা হবে।' %></p>
        <% } %>
      </div>
      <div class="product-tab-panel" id="tab-specs">
        <h3>স্পেসিফিকেশন</h3>
        <table class="spec-table">
          <tr><td>পণ্যের নাম</td><td><%= product.name %></td></tr>
          <% if (product.nameBn) { %><tr><td>নাম (বাংলা)</td><td><%= product.nameBn %></td></tr><% } %>
          <tr><td>ক্যাটাগরি</td><td><%= product.cat %></td></tr>
          <tr><td>SKU</td><td><%= product.sku %></td></tr>
          <tr><td>রেটিং</td><td><%= product.rating %> / 5</td></tr>
          <tr><td>স্টক</td><td><%= product.stock %> পিস</td></tr>
          <% if (product.badge) { %><tr><td>অফার</td><td><%= product.badge.toUpperCase() %></td></tr><% } %>
        </table>
      </div>
      <div class="product-tab-panel" id="tab-reviews">
        <h3 id="reviews">গ্রাহকের রিভিউ</h3>
        <% if (productReviews.length) { %>
          <div class="review-grid product-reviews">
            <% productReviews.forEach(function(r) { %>
              <div class="review-card">
                <div class="review-top">
                  <div class="reviewer-avatar"><%= (r.reviewer_name || '?').slice(0, 2) %></div>
                  <div>
                    <div class="reviewer-name"><%= r.reviewer_name %></div>
                    <div class="stars"><%= '★'.repeat(r.rating) %><%= '☆'.repeat(5 - r.rating) %></div>
                    <div class="reviewer-date"><%= new Date(r.created_at).toLocaleDateString('bn-BD') %></div>
                  </div>
                </div>
                <div class="review-text">"<%= r.comment %>"</div>
                <% if (r.is_verified) { %><div class="verified-badge">✅ Verified Purchase</div><% } %>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="empty-msg">এখনো কোনো রিভিউ নেই। প্রথম রিভিউ আপনি দিন!</p>
        <% } %>
      </div>
      <div class="product-tab-panel" id="tab-delivery">
        <h3>ডেলিভারি ও রিটার্ন</h3>
        <ul class="delivery-list">
          <li>🚚 ঢাকার ভিতরে ২–৪ কর্মদিবস, ঢাকার বাইরে ৩–৭ কর্মদিবস</li>
          <li>💰 ৳<%= ((storeSettings && storeSettings.freeShippingMin) || 1500).toLocaleString('en-US') %>+ অর্ডারে সমগ্র বাংলাদেশে ফ্রি ডেলিভারি</li>
          <li>💳 bKash, Rocket, Nagad — ম্যানুয়াল পেমেন্ট, Trx ID দিয়ে অর্ডার কনফার্ম</li>
          <li>🔄 ৩০ দিনের মধ্যে ত্রুটিপূর্ণ পণ্য রিটার্ন/রিপ্লেসমেন্ট</li>
          <% if (storeSettings && storeSettings.supportPhone) { %>
          <li>📞 সাপোর্ট: <%= storeSettings.supportPhone %> (সকাল ৯টা – রাত ৯টা)</li>
          <% } else if (storeSettings && storeSettings.supportEmail) { %>
          <li>📧 সাপোর্ট: <%= storeSettings.supportEmail %></li>
          <% } %>
        </ul>
      </div>
    </div>

    <% if (related.length) { %>
    <section class="product-section">
      <div class="section-header">
        <h2 class="section-title">🔗 সম্পর্কিত পণ্য — <%= product.cat %></h2>
        <a href="/category/<%= product.catSlug %>" class="see-all">সব দেখুন →</a>
      </div>
      <div class="product-grid">
        <% related.forEach(function(p) { %>
          <%- include('partials/product-card', { p: p }) %>
        <% }); %>
      </div>
    </section>
    <% } %>

    <% if (alsoLike.length) { %>
    <section class="product-section">
      <div class="section-header">
        <h2 class="section-title">✨ আপনার জন্য আরও পণ্য</h2>
        <a href="/#products" class="see-all">সব পণ্য →</a>
      </div>
      <div class="product-grid">
        <% alsoLike.forEach(function(p) { %>
          <%- include('partials/product-card', { p: p }) %>
        <% }); %>
      </div>
    </section>
    <% } %>

    <section class="product-section" id="recentSection" style="display:none;">
      <h2 class="section-title">🕐 সম্প্রতি দেখা পণ্য</h2>
      <div class="product-grid" id="recentGrid"></div>
    </section>
  </div>
</div>

<%- include('partials/site-footer', { storeSettings }) %>
<%- include('partials/cart-modals', { storeSettings }) %>

<script>
  window.__WN_STORE__ = <%- JSON.stringify(storeSettings || {}) %>;
  window.__PRODUCT_PAGE__ = <%- JSON.stringify({
    id: product.id,
    slug: product.slug,
    name: product.name,
    icon: product.icon,
    imageUrl: product.imageUrl,
    images: product.images || [],
    sizes: product.sizes || [],
    fromPrice: product.fromPrice,
    price: product.price,
    original: product.original,
    stock: product.stock,
    catSlug: product.catSlug
  }).replace(/</g, '\\u003c') %>;
  if (window.initProductPage) window.initProductPage();
</script>
<script src="/js/product-page.js?v=5"></script>
</body>
</html>
