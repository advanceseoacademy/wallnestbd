<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('partials/favicon') %>
<%- include('partials/seo-meta', { seo: typeof seo !== 'undefined' ? seo : null, siteUrl: typeof siteUrl !== 'undefined' ? siteUrl : '' }) %>
<% if (typeof seo === 'undefined' || !seo) { %><title>নতুন আরাইভাল — WallNest BD</title><% } %>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css?v=33">
</head>
<body>

<%- include('partials/site-header', { categories, cartCount, user, activeNav: 'new-arrivals' }) %>

<div class="site-wrap site-main new-arrivals-page">
  <nav class="breadcrumb" style="margin-bottom:20px;">
    <a href="/">হোম</a> / <span>নতুন আরাইভাল</span>
  </nav>
  <div class="section-header">
    <h1 class="section-title">🆕 নতুন আরাইভাল / <span>New Arrival</span></h1>
    <a href="/" class="see-all">← হোমে ফিরুন</a>
  </div>
  <p class="new-arrivals-page-desc">সর্বশেষ আপলোড করা সব পণ্য — নতুন থেকে পুরনো ক্রমে।</p>
  <% if (newArrivalProducts && newArrivalProducts.length) { %>
  <div class="product-grid">
    <% newArrivalProducts.forEach(function(p) { %>
      <%- include('partials/product-card', { p: p }) %>
    <% }); %>
  </div>
  <% } else { %>
  <div class="new-arrivals-empty">
    <p>এখনো নতুন পণ্য নেই। অ্যাডমিন প্যানেল থেকে <strong>+ নতুন পণ্য</strong> যোগ করুন।</p>
    <a href="/" class="btn-primary" style="display:inline-block;margin-top:16px;text-decoration:none;">হোমপেজ</a>
  </div>
  <% } %>
</div>

<%- include('partials/site-footer') %>
<%- include('partials/cart-modals') %>
<script src="/js/app.js"></script>
</body>
</html>
