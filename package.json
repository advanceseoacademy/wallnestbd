{
  "name": "wallnest-bd",
  "version": "1.0.0",
  "description": "WallNest BD E-commerce (Next.js + Supabase)",
  "scripts": {
    "dev": "concurrently -k -n web,admin -c blue,green \"npm run dev:web\" \"npm run dev:admin-api\"",
    "dev:web": "next dev -p 3000",
    "dev:admin-api": "npm run start:dev --prefix admin-api",
    "build": "npm run build --prefix admin-api && next build",
    "start": "concurrently -k \"next start -p 3000\" \"npm run start:prod --prefix admin-api\"",
    "dev:express": "node --watch server.js",
    "setup:db": "node scripts/setup-db.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "seed:reviews": "node scripts/seed-reviews.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "iron-session": "^8.0.4",
    "multer": "^1.4.5-lts.1",
    "next": "^15.5.19",
    "nodemailer": "^8.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.33.5",
    "uuid": "^11.0.5",
    "ws": "^8.21.0"
  }
}
